# Force LF for cross-platform shell/scripts (avoids bash\r on Windows/WSL/Git Bash)
* text=auto eol=lf

*.sh text eol=lf
mvnw text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
