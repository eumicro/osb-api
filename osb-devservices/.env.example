# Copy to .env (gitignored) and adjust as needed.
POSTGRES_DB=osb
POSTGRES_USER=osb
POSTGRES_PASSWORD=osb
POSTGRES_PORT=5432
# n8n uses the same user/password against the separate database "n8n" (see postgres/init).

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180

N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=osb-dev-n8n-encryption-key
N8N_OIDC_CLIENT_SECRET=osb-n8n-dev-secret
OSB_N8N_BRIDGE_SECRET=osb-n8n-bridge-dev-secret
OSB_N8N_CLIENT_TOKEN=osb-n8n-client-dev-secret
# n8n → osb-api on the Compose network (apps are built/started by compose).
OSB_API_BASE_URL=http://osb-api:8080
OSB_CLIENT_ALLOW_LOCAL_FALLBACK=false
OSB_API_PORT=8080
OSB_BFF_PORT=8081
OSB_API_DEBUG_PORT=5005
OSB_BFF_DEBUG_PORT=5006
# Optional: pull GHCR images via docker-compose.ghcr.yml (defaults shown)
# OSB_API_IMAGE=ghcr.io/eumicro/osb-api/osb-api:latest
# OSB_BFF_IMAGE=ghcr.io/eumicro/osb-api/osb-bff:latest
# Editor embedded in OSB Admin; BFF propagates Keycloak session via bridge ticket.
# Custom n8n nodes: OSB Git / OSB Kubernetes / OSB HTTP (types CUSTOM.osb*).
# Editor is locked down via NODES_INCLUDE in docker-compose.yml (webhook + respond + OSB only).

# Gitea (Git server for provision templates; HTTPS only)
GITEA_HTTP_PORT=3000
GITEA_ROOT_URL=http://localhost:3000/
GITEA_ADMIN_USER=osb
GITEA_ADMIN_PASSWORD=osb
GITEA_ADMIN_EMAIL=osb@localhost
# Realtest Gitea repo: gitea/repos/git-demo-templates → osb/git-demo-templates

# Kind (created by scripts/kind-up.sh; not a Compose service)
KIND_CLUSTER_NAME=osb
KIND_API_PORT=6443
KIND_NAMESPACE=osb-demo
# OSB_SKIP_KIND=true

TZ=Europe/Berlin
